# Runtime mode: mock | live
BOT_MODE=mock

# Solana RPC (required for live mode)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Axiom terminal API (optional — extends on-chain execution routing)
AXIOM_API_KEY=
AXIOM_API_URL=https://api.axiom.trade

# Jupiter quote API
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6

# HTTP API server
PORT=8790
HOST=127.0.0.1

# Scan interval in milliseconds (continuous scan mode)
SCAN_INTERVAL_MS=5000

# Risk controls
MIN_PROFIT_BPS=15
MAX_SLIPPAGE_BPS=50
MAX_TRADE_SIZE_SOL=1
MAX_DAILY_TRADES=100
MAX_CONSECUTIVE_FAILURES=5

# Execution — NEVER enable on mainnet without review
EXECUTION_ENABLED=false
DRY_RUN=true

# Wallet (base58 secret key — keep secure, never commit)
WALLET_PRIVATE_KEY=

# Token pairs to monitor (comma-separated mint addresses or symbols)
WATCH_TOKENS=SOL,USDC,BONK,WIF,JUP

# Logging: debug | info | warn | error
LOG_LEVEL=info
